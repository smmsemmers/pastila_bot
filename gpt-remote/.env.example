# pastila-gpt-remote (@pastila_gPT_remote_bot) — environment template
# Copy to .env and fill in real values. Never commit .env.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# LLM: если задан OPENROUTER_API_KEY — бот идёт через OpenRouter с авто-подбором
# модели под задачу (см. ROUTES в index.mjs):
#   chat      → anthropic/claude-opus-4.8   (диалог, тексты, структура)
#   code      → openai/gpt-5.3-codex        (код, техника, отладка)
#   reasoning → openai/gpt-5.5              (анализ, стратегия, планирование)
#   vision/OCR→ google/gemini-3.1-pro-preview (картинки, OCR)
# Классификатор типа задачи: google/gemini-2.5-flash-lite.
# /research и /agent используют выбор через /model (по умолчанию GPT-5.5),
# а глубокий /agent — perplexity/sonar-deep-research.
# Без OPENROUTER_API_KEY бот откатывается на прямой OpenAI с одной моделью OPENAI_MODEL.
OPENROUTER_API_KEY=

# OpenAI: fallback-модель (когда нет OpenRouter) и/или Codex CLI.
# OPENAI_MODEL — именно fallback, а не основная модель при работающем OpenRouter.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Access control (comma-separated Telegram numeric IDs)
ALLOWED_USER_IDS=
ALLOWED_CHAT_IDS=

# Codex / local command execution (optional)
ENABLE_CODEX=false
CODEX_WORKDIR=
CODEX_SANDBOX=
CODEX_TIMEOUT_MS=
